APP_NAME=Local Ollama AI Dashboard
ENVIRONMENT=development

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Comma-separated list of allowed frontend origins (no trailing slash).
# Add your deployed frontend URL here, e.g. https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

DATABASE_URL=sqlite:///./ollama_dashboard.db

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

API_KEY_PREFIX=sk-ollama
API_KEY_SECRET_PEPPER=change-this-random-secret

FAKE_COST_PER_TOKEN=0.000001

# Password the dashboard (admin) endpoints require via the X-Admin-Password header.
ADMIN_PASSWORD=change-this-admin-password

# Privacy + limits
LOG_PROMPTS=true
PROMPT_PREVIEW_CHARS=200
RATE_LIMIT_PER_MINUTE=60
