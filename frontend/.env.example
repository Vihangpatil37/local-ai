# URL of the FastAPI backend.
# Local development:
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# When the backend is exposed via Cloudflare Tunnel, use that public URL instead:
# NEXT_PUBLIC_BACKEND_URL=https://ai.yourdomain.com

# Admin password for the dashboard (must match backend ADMIN_PASSWORD).
# This is sent from the browser to read admin endpoints. For a public deploy,
# prefer entering it in the dashboard UI at runtime rather than committing it.
NEXT_PUBLIC_ADMIN_PASSWORD=change-this-admin-password
